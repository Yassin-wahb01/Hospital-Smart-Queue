PORT=5000

# MongoDB — replicaSet required for transactions
# Local dev (docker-compose): mongodb://localhost:27017/medicare?replicaSet=rs0
# Production: use MongoDB Atlas free cluster (already a replica set by default)
MONGODB_URI=mongodb://localhost:27017/medicare?replicaSet=rs0

# JWT secrets — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=change_me_min_32_chars
JWT_REFRESH_SECRET=change_me_min_32_chars_different

# CORS — set to the deployed Vercel client URL in production
# Leave as localhost for local dev
CLIENT_ORIGIN=http://localhost:5173

NODE_ENV=development
